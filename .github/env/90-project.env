# ================================================================================================
# 🏗️ PROJECT-SPECIFIC OVERRIDES (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific configuration overrides for go-bsv-middleware
# Load Order: 90 (loaded after all defaults, overrides earlier files)
#
# This file contains settings specific to this repository that should NOT be
# synced to other repos via go-broadcast. Use this file for:
# - Coverage provider and threshold overrides
# - Project-specific security tool configuration
# - Coverage exclusion paths matching codecov.yml
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X CONFIGURATION
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER
# ================================================================================================

# Use Codecov as the coverage provider (overrides internal default)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS (matching codecov.yml ignore paths)
# ================================================================================================

GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,test/,testing/,vendor/,testdata/

# ================================================================================================
# 🔒 SECURITY CONFIGURATION
# ================================================================================================

# Custom gitleaks configuration file
GITLEAKS_CONFIG_FILE=.github/.gitleaks.toml
